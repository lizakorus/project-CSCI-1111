#include <iostream>
#include <vector>
#include <string>
using namespace std;

#define KINGS_CHAMBER 1
#define DARK_CORRIDOR 2
#define SECRET_ROOM 3
#define EXIT_CHAMBER 4
#define MAX_TIME 10

vector<int> leverCode = {1, 1, 0, 1, 0};

class Item {
private:
    string name;
    string description;
    int healthEffect;

public:
    Item(string n, string d, int h) {
        name = n;
        description = d;
        healthEffect = h;
    }

    string getName() {
        return name;
    }

    string getDescription() {
        return description;
    }

    int getHealthEffect() {
        return healthEffect;
    }
};

Item torch("Torch", "Helps you see in the dark", 0);
Item rope("Rope", "Used to cross pits safely", 0);
Item elixir("Elixir", "Restores health when used", 3);
Item key("Ancient key", "Opens the final chamber", 0);

void changeHealth(int *health, int amount) {
    *health += amount;

    if (amount < 0 && *health > 0) {
        cout << "You lost health!" << endl;
    } else if (amount > 0) {
        cout << "You gained health!" << endl;
    }

    cout << "Your health: " << *health << endl;

    if (*health <= 0) {
        cout << "----------------------------------" << endl;
        cout << "You lost all your health!" << endl;
        cout << "You died!" << endl;
    }
}

int main() {
    int playAgain = 1;

    while (playAgain == 1) {
        vector<Item> inventory;

        int health = 3;
        int currentRoom = KINGS_CHAMBER;
        int timeLeft = MAX_TIME;
        int gameOver = 0;

        cout << "\nYou are an archaeologist who one day wakes up in the 26th C.B.E. in the Pyramid of Giza.\n";
        cout << "You are inside the tomb of Pharaoh Khufu, accidentally disturbing his slumber.\n";
        cout << "You must escape by navigating through The Kings Chamber, The Dark Corridor, and finally The Exit Chamber.\n";
        cout << "Beware the deadly traps. Escape before time runs out.\n";
        cout << "----------------------------------\n";
        cout << "You have " << health << " health points.\n";
        cout << "----------------------------------\n";

        while (!gameOver && timeLeft > 0) {
            switch (currentRoom) {

                case KINGS_CHAMBER: {
                    int choice;
                    int doorChoice;

                    cout << "Kings Chamber:" << endl;
                    cout << "You are encapsulated in darkness." << endl;

                    while (true) {
                        timeLeft--;
                        cout << "Time Remaining: " << timeLeft << endl;

                        if (timeLeft <= 0) {
                            gameOver = 1;
                            break;
                        }

                        cout << "Check inventory? 1 = yes 0 = no" << endl;
                        cin >> choice;

                        if (choice == 0) {
                            cout << "You did not check inventory." << endl;
                            cout << "You cannot navigate in the darkness." << endl;

                            changeHealth(&health, -1);

                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }

                            continue;
                        }

                        break;
                    }

                    if (gameOver) {
                        break;
                    }

                    while (true) {
                        if (health <= 0 || timeLeft <= 0) {
                            gameOver = 1;
                            break;
                        }

                        cout << "You found an item!" << endl;
                        inventory.push_back(torch);
                        cout << "You have a " << torch.getName() << ". Light it? 1=yes 0=no" << endl;
                        cout << torch.getDescription() << endl;

                        cin >> choice;

                        if (choice == 0) {
                            cout << "You remain in darkness." << endl;
                            changeHealth(&health, -1);

                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }

                            continue;
                        } else if (choice == 1) {
                            cout << "You light the " << torch.getName() << " and escape the darkness." << endl;
                            break;
                        }
                    }

                    if (gameOver) {
                        break;
                    }

                    while (true) {
                        if (health <= 0 || timeLeft <= 0) {
                            gameOver = 1;
                            break;
                        }

                        timeLeft--;
                        cout << "Time Remaining: " << timeLeft << endl;

                        if (timeLeft <= 0) {
                            gameOver = 1;
                            break;
                        }

                        cout << "Two doors stand before you." << endl;
                        cout << "One leads to certain death." << endl;
                        cout << "Choose wisely: 1 = Door One  0 = Door Two" << endl;

                        cin >> doorChoice;

                        if (doorChoice != 1) {
                            cout << "Wrong door! Spikes shoot from the walls!" << endl;
                            changeHealth(&health, -1);

                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }

                            continue;
                        } else {
                            cout << "You chose wisely." << endl;
                            currentRoom = DARK_CORRIDOR;
                            break;
                        }
                    }

                    break;
                }

                case DARK_CORRIDOR: {
                    int choice;

                    timeLeft--;
                    cout << "Time Remaining: " << timeLeft << endl;

                    if (timeLeft <= 0) {
                        gameOver = 1;
                        break;
                    }

                    cout << "You are in the Dark Corridor. There is a deep pit.\n";
                    cout << "Check room for items? 1 = yes 0 = no\n";
                    cin >> choice;

                    timeLeft--;
                    cout << "Time Remaining: " << timeLeft << endl;

                    if (timeLeft <= 0) {
                        gameOver = 1;
                        break;
                    }

                    if (choice == 1) {
                        cout << "You found an item!\n";
                        inventory.push_back(rope);
                        cout << rope.getName() << endl;
                        cout << rope.getDescription() << endl;

                        currentRoom = SECRET_ROOM;
                    } else {
                        cout << "You fall into the pit!\n";
                        changeHealth(&health, -1);

                        if (health <= 0) {
                            gameOver = 1;
                            break;
                        }
                    }

                    break;
                }

                case SECRET_ROOM: {
                    int choice;

                    cout << "----------------------------------\n";
                    cout << "A strange wall catches your eye.\n";

                    while (true) {
                        cout << "Do you want to look around? 1 = yes 0 = continue\n";
                        cin >> choice;

                        if (choice == 1) {
                            timeLeft--;
                            cout << "Time Remaining: " << timeLeft << endl;

                            if (timeLeft <= 0) {
                                gameOver = 1;
                                break;
                            }

                            cout << "You found a hidden door to a secret room!\n";

                            while (true) {
                                cout << "Open it? 1 = yes 0 = no\n";
                                cin >> choice;

                                if (choice == 1) {
                                    cout << "You enter the secret room.\n";
                                    cout << "You found an item!\n";

                                    inventory.push_back(elixir);
                                    cout << elixir.getName() << endl;
                                    cout << elixir.getDescription() << endl;

                                    changeHealth(&health, elixir.getHealthEffect());

                                    cout << "Carved into the wall is an ancient code:\n";
                                    cout << "[";

                                    for (int i = 0; i < leverCode.size(); i++) {
                                        cout << leverCode[i];

                                        if (i < leverCode.size() - 1) {
                                            cout << ", ";
                                        }
                                    }

                                    cout << "]\n";

                                    currentRoom = EXIT_CHAMBER;
                                    break;
                                } else {
                                    cout << "You hesitate at the doorway.\n";
                                    cout << "A dart trap fires from the wall!\n";

                                    changeHealth(&health, -1);

                                    if (health <= 0) {
                                        gameOver = 1;
                                        break;
                                    }
                                }
                            }

                            break;
                        } else {
                            cout << "You try to move on too quickly.\n";
                            cout << "A hidden trap activates!\n";

                            changeHealth(&health, -1);

                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }
                        }
                    }

                    if (!gameOver && currentRoom != EXIT_CHAMBER) {
                        currentRoom = EXIT_CHAMBER;
                    }

                    break;
                }

                case EXIT_CHAMBER: {
                    int choice;

                    timeLeft--;
                    cout << "Time Remaining: " << timeLeft << endl;

                    if (timeLeft <= 0) {
                        gameOver = 1;
                        break;
                    }

                    cout << "----------------------------------\n";
                    cout << "Exit Chamber:\n";

                    cout << "Search for Ancient Key? 1 = yes 0 = no\n";
                    cin >> choice;

                    timeLeft--;
                    cout << "Time Remaining: " << timeLeft << endl;

                    if (choice == 0 || timeLeft <= 0) {
                        cout << "You are trapped in the tomb.\n";
                        gameOver = 1;
                        break;
                    }

                    cout << "You found an item!\n";
                    inventory.push_back(key);
                    cout << key.getName() << endl;
                    cout << key.getDescription() << endl;

                    int solved = 0;
                    vector<int> lever(5);

                    cout << "Five ancient levers stand before you.\n";
                    cout << "Hint: Use the ancient code from the secret room.\n";

                    while (!solved && timeLeft > 0 && health > 0) {
                        cout << "Enter lever positions, 1 or 0:\n";

                        for (int i = 0; i < lever.size(); i++) {
                            cin >> lever[i];
                        }

                        timeLeft--;
                        cout << "Time Remaining: " << timeLeft << endl;

                        if (lever == leverCode) {
                            solved = 1;
                        } else {
                            cout << "Incorrect combination.\n";
                            changeHealth(&health, -1);

                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }
                        }
                    }

                    if (solved && timeLeft > 0 && health > 0) {
                        while (true) {
                            cout << "A hidden door appears. Use key? 1 = yes 0 = no\n";
                            cin >> choice;

                            timeLeft--;
                            cout << "Time Remaining: " << timeLeft << endl;

                            if (choice == 1 && timeLeft > 0) {
                                cout << "You escape the pyramid!\n";
                                break;
                            } else if (choice == 0 && timeLeft > 0) {
                                cout << "You hesitate, and the tomb punishes your doubt.\n";

                                changeHealth(&health, -1);

                                if (health <= 0) {
                                    gameOver = 1;
                                    break;
                                }
                            } else {
                                cout << "You hesitate. Time runs out.\n";
                                gameOver = 1;
                                break;
                            }
                        }
                    } else {
                        cout << "The Pharaoh awakens!\n";

                        if (timeLeft <= 0 && health > 0) {
                            cout << "You ran out of time and couldn't use your remaining health.\n";
                        }

                        health = 0;
                    }

                    gameOver = 1;
                    break;
                }
            }
        }

        cout << "----------------------------------" << endl;
        cout << "Play again? 1 = yes 0 = no" << endl;
        cin >> playAgain;
    }

    return 0;
}
