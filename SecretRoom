#include <iostream>
#include <vector>
#include <string>
#define KINGS_CHAMBER 1
#define DARK_CORRIDOR 2
#define SECRET_ROOM 3
#define EXIT_CHAMBER 4
#define MAX_TIME 10
using namespace std;

// Initializes lever sequence that is used later
// B-LEVEL FEATURE: using std::vector allows easier comparison and cleaner handling
vector<int> leverCode = {1, 1, 0, 1, 0};

// B-LEVEL FEATURE: Item class represents anything the player can collect and store
// This allows us to avoid hard-coding things like torch/rope/elixir into the game logic
// and instead treat them as reusable objects
class Item {
private:
    string name;          // identifies the item in inventory
    string description;   // helps player understand what the item does
    int healthEffect;     // used for items like elixir that affect health

public:

    // Constructor initializes all properties of an item at creation
    // This keeps item setup consistent and avoids setting values manually later
    Item(string n, string d, int h) {
        name = n;
        description = d;
        healthEffect = h;
    }

    // Returns item name so it can be displayed or checked in logic
    string getName() {
        return name;
    }

    // Returns description so inventory display is more informative
    string getDescription() {
        return description;
    }

    // Returns health effect so items can modify player health when used
    int getHealthEffect() {
        return healthEffect;
    }
};
// These are the actual items used throughout the game
// Creating them once avoids duplicating code in each room
Item torch("Torch", "Helps you see in the dark", 0);
Item rope("Rope", "Used to cross pits safely", 0);
Item elixir("Elixir", "Restores health when used", 3);
Item key("Ancient key", "Opens the final chamber", 0);

// Updates player's health
void changeHealth(int *health, int amount) {
    
    // Apply damage or healing
    *health += amount;

    // Message for damage or healing
    if (amount < 0 && *health > 0) {
        cout << "You lost health!" << endl;
    } else if (amount > 0) {
        cout << "You gained health!" << endl;
    }

    // Show current health
    cout << "Your health: " << *health << endl;

    // Check if player is dead
    if (*health <= 0) {
        cout << "----------------------------------" << endl;
        cout << "You lost all your health!" << endl;
        cout << "You died!" << endl;
    }
}

int main () {

    int playAgain = 1;

    // ================= REPLAY LOOP =================
    // Whole game restarts if user enters 1
    while (playAgain == 1) {
        vector<Item> inventory; //resets every game
        
        int health = 3;
        int currentRoom = KINGS_CHAMBER;
        int timeLeft = MAX_TIME;
        int gameOver = 0;

        cout << "\nYou are an archaeologist who one day wakes up in the 26th C.B.E. in the Pyramid of Giza.\n";
        cout << "You are inside the tomb of Pharaoh Khufu, accidently disturbing his slumber.\n";
        cout << "You must escape by navigating through The Kings Chamber, The Dark Corridor, and finally The Exit Chamber.\n";
        cout << "Beware the deadly traps. Escape before time runs out.\n";
        cout << "----------------------------------\n";
        cout << "You have " << health << " health points.\n";
        cout << "----------------------------------\n"; 

        // ================= MAIN GAME LOOP =================
        while (!gameOver && timeLeft > 0) {

            switch(currentRoom) {

                // ================= ROOM 1 - KINGS CHAMBER=================
                case KINGS_CHAMBER: {

                    int choice;
                    int doorChoice;

                    cout << "Kings Chamber:" << endl;
                    cout << "You are encapsulated in darkness." << endl;
                    
                    //Inventory
                    while (true){
                     if (timeLeft > 0){
                     timeLeft--;
                    }
                    cout << "Time Remaining: " << timeLeft << endl;

                    // INVENTORY Check 
                    cout << "Check inventory? 1 = yes 0 = no" << endl;
                    cin >> choice; 
                   
                    
                    if (choice == 0) {
                            cout << "You did not check inventory." << endl;
                            cout << "You cannot navigate in the darkness." << endl;

                            changeHealth(&health, -1);

                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }
                            continue; 
                        }
                        break; // move on
                    }
                    // TORCH LOOP
                    while (true){
                        if (health <= 0 || timeLeft <= 0) {
                                gameOver = 1;
                                break;
                        } 
                    
                       
                            cout << "You found an item!" << endl;
                            inventory.push_back(torch); // puts torch into inventory
                            cout << "You have a " << torch.getName()<< ". Light it? 1=yes 0=no"<<endl; // show what item does
    		                cout << torch.getDescription() << endl; //show what item does
                            
                            cin >> choice;
                            if (choice == 0) {
                                    cout << "You remain in darkness." << endl;
                                    //Player takes damage
                                    changeHealth(&health, -1);
                                    if (health <= 0) {
                                        gameOver = 1;
                                        break;
                                    }
                            
                                    continue; // retry torch question
                            
                            }else if(choice == 1) {
                                cout << "You light the " << torch.getName() << " and escape the darkness."<<endl;
                                break; //move on
                                }
                        
                        
                    }
                    
                  
                    // DOOR Loop
                    while (true){
                        if (health <= 0 || timeLeft <= 0) {
                            gameOver = 1;
                            break;
                        }
                    
                        timeLeft--;
                        cout<<"Time Remaining: "<<timeLeft<<endl;
    
                        cout << "Two doors stand before you." << endl;
                        cout << "One leads to certain death." << endl;
                        cout << "Choose wisely: 1 = Door One  0 = Door Two" <<endl;
    
                        cin >> doorChoice;
    
                            if (doorChoice != 1) {
                                cout << "Wrong door! Spikes shoot from the walls!" << endl;
                                // Player takes damage
                                changeHealth(&health, -1);
                                if (health <= 0) {
                                    gameOver = 1;
                                    break;
                                }
                                continue; // retry door question
    
                            }
                            else{
                                cout << "You chose wisely." << endl;
                                currentRoom = DARK_CORRIDOR;
                                break; //exit room loop
                            }
                            
                            break;
                    }
}
    
                // ================= ROOM 2 - DARK CORRIDOR =================
                case DARK_CORRIDOR: {

                    // Entering room costs time
                    timeLeft--;
                    cout << "Time Remaining: "<< timeLeft;

                    int choice;

                    cout << endl << "You are in the Dark Corridor." << "There is a deep pit.\n";
                    cout << "Check room for items? 1 = yes 0 = no\n";
                    cin >> choice;

                    // Checking costs time
                    timeLeft--;
                    cout << "Time Remaining: " << timeLeft << endl;

                    if (choice == 1) {
                        cout << "You found an item!\n";

						// Show item name
                        cout << rope.getName() << endl;
                        // Show what item does
                        cout << rope.getDescription() << endl;

                        currentRoom = SECRET_ROOM;

                    } else {
                        cout << "You fall into the pit!\n";

                        // Player takes damage
                        changeHealth(&health, -1);

                        if (health <= 0) {
                            gameOver = 1;
                            break;
                        }
                    }
                    
                    break;
                }
                // ================= ROOM 3 - SECRET ROOM =================
					case SECRET_ROOM: {

						int choice; // stores player input

						cout << "----------------------------------\n";
						cout << "A strange wall catches your eye.\n";

						// loop until player makes a valid choice or dies
						while (true) {
							cout << "Do you want to look around? 1 = yes 0 = continue\n";
							cin >> choice;

							if (choice == 1) {
								timeLeft--; // looking costs time
								cout << "Time Remaining: " << timeLeft << endl;

								cout << "You found a hidden door to a secret room!\n";

								// second decision loop
								while (true) {
									cout << "Open it? 1 = yes 0 = no\n";
									cin >> choice;

									if (choice == 1) {
										cout << "You enter the secret room.\n";
										cout << "You found an item!\n";

										// Show item name
                                        cout << elixir.getName() << endl;
                                        //Show what item does
                                        cout << elixir.getDescription() << endl;

										changeHealth(&health, elixir.getHealthEffect()); // heal player +3

										// display lever code from shared vector
										cout << "Carved into the wall is an ancient code:\n";
										cout << "[";
										for (int i = 0; i < leverCode.size(); i++) {
											cout << leverCode[i];
											if (i < leverCode.size() - 1) {
												cout << ", ";
											}
										}
										cout << "]\n";

										currentRoom = EXIT_CHAMBER; // move to next room
										break;
									} else {
										cout << "You hesitate at the doorway.\n";
										cout << "A dart trap fires from the wall!\n";

										changeHealth(&health, -1); // take damage

										// check if player died
										if (health <= 0) {
											gameOver = 1;
											break;
										}
									}
								}

								break;
							} else {
								cout << "You try to move on too quickly.\n";
								cout << "A hidden trap activates!\n";

								changeHealth(&health, -1); // trap damage

								// check death
								if (health <= 0) {
									gameOver = 1;
									break;
								}
							}
						}

						// safety: ensure player moves forward
						if (!gameOver && currentRoom != EXIT_CHAMBER) {
							currentRoom = EXIT_CHAMBER;
						}

						break;
					}

					case EXIT_CHAMBER: {

						timeLeft--; // entering room costs time
						cout << "Time Remaining: " << timeLeft << endl;

						int choice;

						cout << "----------------------------------\n";
						cout << "Exit Chamber:\n";

						// if time runs out immediately
						if (timeLeft <= 0) {
							gameOver = 1;
							break;
						}

						cout << "Search for Ancient Key? 1 = yes 0 = no\n";
						cin >> choice;

						timeLeft--; // searching costs time
						cout << "Time Remaining: " << timeLeft << endl;

						// fail condition
						if (choice == 0 || timeLeft <= 0) {
							cout << "You are trapped in the tomb.\n";
							gameOver = 1;
							break;
						}

						cout << "You found an item!\n";

						// Show item name
                        cout << key.getName() << endl;
                        // Show what item does
                        cout << key.getDescription() << endl;

						int solved = 0; // puzzle solved flag
						vector<int> lever(5); // player input array

						cout << "Five ancient levers stand before you.\n";
						cout << "Hint: The door opens with the number 26.\n";

						// loop until solved, dead, or out of time
						while (!solved && timeLeft > 0 && health > 0) {

							cout << "Enter lever positions (1 or 0):\n";

							// collect input into vector
							for (int i = 0; i < lever.size(); i++) {
								cin >> lever[i];
							}

							timeLeft--; // each attempt costs time
							cout << "Time Remaining: " << timeLeft << endl;

							// compare player input to correct code
							if (lever == leverCode) {
								solved = 1; // correct answer
							} else {
								cout << "Incorrect combination.\n";

								changeHealth(&health, -1); // penalty damage

								// check death
								if (health <= 0) {
									gameOver = 1;
									break;
								}
							}
						}

						// success path
						if (solved && timeLeft > 0 && health > 0) {

							while (true) {
								cout << "A hidden door appears. Use key? 1 = yes 0 = no\n";
								cin >> choice;

								timeLeft--; // decision costs time
								cout << "Time Remaining: " << timeLeft << endl;

								if (choice == 1 && timeLeft > 0) {
									cout << "You escape the pyramid!\n";
									break;
								} else if (choice == 0 && timeLeft > 0) {
									cout << "You hesitate, and the tomb punishes your doubt.\n";

									changeHealth(&health, -1); // hesitation penalty

									if (health <= 0) {
										gameOver = 1;
										break;
									}
								} else {
									cout << "You hesitate. Time runs out.\n";
									gameOver = 1;
									break;
								}
							}

						} else {
							// failure path 
							cout << "The Pharaoh awakens!\n";

							if (timeLeft <= 0 && health > 0) {
								cout << "You ran out of time and couldn't use your remaining health.\n";
							}

							health = 0; // force death
						}

						gameOver = 1; // game ends after this room
						break;
					}
			}		
		}
	}
	return 0;
}

