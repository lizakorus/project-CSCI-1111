#include <stdio.h>
#define KINGS_CHAMBER 1
#define DARK_CORRIDOR 2
#define SECRET_ROOM 3
#define EXIT_CHAMBER 4
#define MAX_TIME 10
#include <vector>

// Initializes lever sequence that is used later
// B-LEVEL FEATURE: using std::vector allows easier comparison and cleaner handling
vector<int> leverCode = {1, 1, 0, 1, 0};

// Updates player's health
void changeHealth(int *health, int amount) {
    
    // Apply damage or healing
    *health += amount;

    // Message for damage or healing
    if (amount < 0 && *health > 0) {
        printf("You lost health!\n");
    } else if (amount > 0) {
        printf("You gained health!\n");
    }

    // Show current health
    printf("Your health: %d\n", *health);

    // Check if player is dead
    if (*health <= 0) {
        printf("----------------------------------\n");
        printf("You lost all your health!\n");
        printf("You died!\n");
    }
}

int main () {

    int playAgain = 1;

    // ================= REPLAY LOOP =================
    // Whole game restarts if user enters 1
    while (playAgain == 1) {

        int health = 3;
        int currentRoom = KINGS_CHAMBER;
        int timeLeft = MAX_TIME;
        int gameOver = 0;

        printf("\nYou are an archaeologist who one day wakes up in the 26th C.B.E. in the Pyramid of Giza.\n");
        printf("You are inside the tomb of Pharaoh Khufu, accidently disturbing his slumber.\n");
        printf("You must escape by navigating through The Kings Chamber, The Dark Corridor, and finally The Exit Chamber.\n");
        printf("Beware the deadly traps. Escape before time runs out.\n");
        printf("----------------------------------\n");
        printf("You have %d health points.\n", health);
        printf("----------------------------------\n");

        // ================= MAIN GAME LOOP =================
        // Runs until player dies or time reaches 0
        while (!gameOver && timeLeft > 0) {

            switch(currentRoom) {

                // ================= ROOM 1 - KINGS CHAMBER =================
                case KINGS_CHAMBER: {

                    int choice;
                    int doorChoice;

                    printf("Kings Chamber:\nYou are encapsulated in darkness.\n");

                    // INVENTORY LOOP 

                    while (1) {

                        if (health <= 0 || timeLeft <= 0) {
                            gameOver = 1;
                            break;
                        }

                        if (timeLeft > 0) timeLeft--;
                        printf("Time Remaining: %d\n", timeLeft);

                        printf("Check inventory? 1 = yes 0 = no\n");
                        scanf("%d", &choice);

                        if (choice == 0) {
                            printf("You did not check inventory.\n");
                            printf("You cannot navigate in the darkness.\n");

                            // Player takes damage
                            changeHealth(&health, -1);
                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }

                            continue; // retry inventory question
                        }

                        break; // move on
                    }

                    // TORCH LOOP
                    while (1) {
                        if (health <= 0 || timeLeft <= 0) {
                            gameOver = 1;
                            break;
                        }

                        printf("You have a torch. Light it? 1 = yes 0 = no\n");
                        scanf("%d", &choice);

                        if (choice == 0) {
                            printf("You remain in darkness.\n");

                            // Player takes damage
                            changeHealth(&health, -1);
                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }

                            continue; // retry torch question
                        }

                        printf("You light the torch and escape the darkness.\n");
                        break; // move on
                    }

                    // DOOR LOOP
                    while (1) {
                        if (health <= 0 || timeLeft <= 0) {
                            gameOver = 1;
                            break;
                        }
                        printf("Two doors stand before you.\n");
                        printf("One leads to certain death.\n");
                        printf("Choose wisely: 1 = Door One  0 = Door Two\n");
                        scanf("%d", &doorChoice);

                        if (doorChoice != 1) {
                            printf("Wrong door! Spikes shoot from the walls!\n");

                            // Player takes damage
                            changeHealth(&health, -1);
                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }

                            continue; // retry door question
                        }                     

                        printf("You chose wisely.\n");
                        currentRoom = DARK_CORRIDOR;
                        break; // exit room loop
                    }

                    break;
                }
    
                // ================= ROOM 2 - DARK CORRIDOR =================
                case DARK_CORRIDOR: {

                    // Entering room costs time
                    timeLeft--;
                    printf("Time Remaining: %d\n", timeLeft);

                    int choice;

                    printf("\nYou are in the Dark Corridor.\nThere is a deep pit.\n");
                    printf("Check room for items? 1 = yes 0 = no\n");
                    scanf("%d", &choice);

                    // Checking costs time
                    timeLeft--;
                    printf("Time Remaining: %d\n", timeLeft);

                    if (choice == 1) {
                        printf("You found a rope!\n");
                        printf("You use it to cross safely.\n");
                        currentRoom = SECRET_ROOM;

                    } else {
                        printf("You fall into the pit!\n");

                        // Player takes damage
                        changeHealth(&health, -1);

                        if (health <= 0) {
                            gameOver = 1;
                            break;
                        }
                    }
                    
                    break;
                }
                // ================= ROOM 3 - SECRET ROOM =================
					case SECRET_ROOM: {

						int choice; // stores player input

						cout << "----------------------------------\n";
						cout << "A strange wall catches your eye.\n";

						// loop until player makes a valid choice or dies
						while (true) {
							cout << "Do you want to look around? 1 = yes 0 = continue\n";
							cin >> choice;

							if (choice == 1) {
								timeLeft--; // looking costs time
								cout << "Time Remaining: " << timeLeft << endl;

								cout << "You found a hidden door to a secret room!\n";

								// second decision loop
								while (true) {
									cout << "Open it? 1 = yes 0 = no\n";
									cin >> choice;

									if (choice == 1) {
										cout << "You enter the secret room.\n";
										cout << "You found a secret elixir!\n";

										player.changeHealth(3); // heal player +3

										// display lever code from shared vector
										cout << "Carved into the wall is an ancient code:\n";
										cout << "[";
										for (int i = 0; i < leverCode.size(); i++) {
											cout << leverCode[i];
											if (i < leverCode.size() - 1) {
												cout << ", ";
											}
										}
										cout << "]\n";

										currentRoom = EXIT_CHAMBER; // move to next room
										break;
									} else {
										cout << "You hesitate at the doorway.\n";
										cout << "A dart trap fires from the wall!\n";

										player.changeHealth(-1); // take damage

										// check if player died
										if (player.getHealth() <= 0) {
											gameOver = 1;
											break;
										}
									}
								}

								break;
							} else {
								cout << "You try to move on too quickly.\n";
								cout << "A hidden trap activates!\n";

								player.changeHealth(-1); // trap damage

								// check death
								if (player.getHealth() <= 0) {
									gameOver = 1;
									break;
								}
							}
						}

						// safety: ensure player moves forward
						if (!gameOver && currentRoom != EXIT_CHAMBER) {
							currentRoom = EXIT_CHAMBER;
						}

						break;
					}

					case EXIT_CHAMBER: {

						timeLeft--; // entering room costs time
						cout << "Time Remaining: " << timeLeft << endl;

						int choice;

						cout << "----------------------------------\n";
						cout << "Exit Chamber:\n";

						// if time runs out immediately
						if (timeLeft <= 0) {
							gameOver = 1;
							break;
						}

						cout << "Search for Ancient Key? 1 = yes 0 = no\n";
						cin >> choice;

						timeLeft--; // searching costs time
						cout << "Time Remaining: " << timeLeft << endl;

						// fail condition
						if (choice == 0 || timeLeft <= 0) {
							cout << "You are trapped in the tomb.\n";
							gameOver = 1;
							break;
						}

						cout << "You found the Ancient Key!\n";

						int solved = 0; // puzzle solved flag
						vector<int> lever(5); // player input array

						cout << "Five ancient levers stand before you.\n";
						cout << "Hint: The door opens with the number 26.\n";

						// loop until solved, dead, or out of time
						while (!solved && timeLeft > 0 && player.getHealth() > 0) {

							cout << "Enter lever positions (1 or 0):\n";

							// collect input into vector
							for (int i = 0; i < lever.size(); i++) {
								cin >> lever[i];
							}

							timeLeft--; // each attempt costs time
							cout << "Time Remaining: " << timeLeft << endl;

							// compare player input to correct code
							if (lever == leverCode) {
								solved = 1; // correct answer
							} else {
								cout << "Incorrect combination.\n";

								player.changeHealth(-1); // penalty damage

								// check death
								if (player.getHealth() <= 0) {
									gameOver = 1;
									break;
								}
							}
						}

						// success path
						if (solved && timeLeft > 0 && player.getHealth() > 0) {

							while (true) {
								cout << "A hidden door appears. Use key? 1 = yes 0 = no\n";
								cin >> choice;

								timeLeft--; // decision costs time
								cout << "Time Remaining: " << timeLeft << endl;

								if (choice == 1 && timeLeft > 0) {
									cout << "You escape the pyramid!\n";
									break;
								} else if (choice == 0 && timeLeft > 0) {
									cout << "You hesitate, and the tomb punishes your doubt.\n";

									player.changeHealth(-1); // hesitation penalty

									if (player.getHealth() <= 0) {
										gameOver = 1;
										break;
									}
								} else {
									cout << "You hesitate. Time runs out.\n";
									gameOver = 1;
									break;
								}
							}

						} else {
							// failure path 
							cout << "The Pharaoh awakens!\n";

							if (timeLeft <= 0 && player.getHealth() > 0) {
								cout << "You ran out of time and couldn't use your remaining health.\n";
							}

							player.health = 0; // force death
						}

						gameOver = 1; // game ends after this room
						break;
					}
