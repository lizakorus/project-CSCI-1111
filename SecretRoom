#include <stdio.h>
#define KINGS_CHAMBER 1
#define DARK_CORRIDOR 2
#define SECRET_ROOM 3
#define EXIT_CHAMBER 4
#define MAX_TIME 10

// Updates player's health
void changeHealth(int *health, int amount) {
    
    // Apply damage or healing
    *health += amount;

    // Message for damage or healing
    if (amount < 0 && *health > 0) {
        printf("You lost health!\n");
    } else if (amount > 0) {
        printf("You gained health!\n");
    }

    // Show current health
    printf("Your health: %d\n", *health);

    // Check if player is dead
    if (*health <= 0) {
        printf("----------------------------------\n");
        printf("You lost all your health!\n");
        printf("You died!\n");
    }
}

int main () {

    int playAgain = 1;

    // ================= REPLAY LOOP =================
    // Whole game restarts if user enters 1
    while (playAgain == 1) {

        int health = 3;
        int currentRoom = KINGS_CHAMBER;
        int timeLeft = MAX_TIME;
        int gameOver = 0;

        printf("\nYou are an archaeologist who one day wakes up in the 26th C.B.E. in the Pyramid of Giza.\n");
        printf("You are inside the tomb of Pharaoh Khufu, accidently disturbing his slumber.\n");
        printf("You must escape by navigating through The Kings Chamber, The Dark Corridor, and finally The Exit Chamber.\n");
        printf("Beware the deadly traps. Escape before time runs out.\n");
        printf("----------------------------------\n");
        printf("You have %d health points.\n", health);
        printf("----------------------------------\n");

        // ================= MAIN GAME LOOP =================
        // Runs until player dies or time reaches 0
        while (!gameOver && timeLeft > 0) {

            switch(currentRoom) {

                // ================= ROOM 1 - KINGS CHAMBER =================
                case KINGS_CHAMBER: {

                    int choice;
                    int doorChoice;

                    printf("Kings Chamber:\nYou are encapsulated in darkness.\n");

                    // INVENTORY LOOP 
                    while (1) {
                        timeLeft--;
                        printf("Time Remaining: %d\n", timeLeft);

                        printf("Check inventory? 1 = yes 0 = no\n");
                        scanf("%d", &choice);

                        if (choice == 0) {
                            printf("You did not check inventory.\n");
                            printf("You cannot navigate in the darkness.\n");

                            // Player takes damage
                            changeHealth(&health, -1);

                            continue; // retry inventory question
                        }

                        break; // move on
                    }

                    // TORCH LOOP
                    while (1) {
                        printf("You have a torch. Light it? 1 = yes 0 = no\n");
                        scanf("%d", &choice);

                        if (choice == 0) {
                            printf("You remain in darkness.\n");

                            // Player takes damage
                            changeHealth(&health, -1);

                            continue; // retry torch question
                        }

                        printf("You light the torch and escape the darkness.\n");
                        break; // move on
                    }

                    // DOOR LOOP
                    while (1) {
                        printf("Two doors stand before you.\n");
                        printf("One leads to certain death.\n");
                        printf("Choose wisely: 1 = Door One  0 = Door Two\n");
                        scanf("%d", &doorChoice);

                        timeLeft--;
                        printf("Time Remaining: %d\n", timeLeft);

                        if (doorChoice == 0) {
                            printf("Wrong door! Spikes shoot from the walls!\n");

                            // Player takes damage
                            changeHealth(&health, -1);

                            continue; // retry door question
                        }

                        printf("You chose wisely.\n");
                        currentRoom = DARK_CORRIDOR;
                        break; // exit room loop
                    }

                    break;
                }
                // ================= ROOM 2 - DARK CORRIDOR =================
                case DARK_CORRIDOR: {

                    // Entering room costs time
                    timeLeft--;
                    printf("Time Remaining: %d\n", timeLeft);

                    int choice;

                    printf("\nYou are in the Dark Corridor.\nThere is a deep pit.\n");
                    printf("Check room for items? 1 = yes 0 = no\n");
                    scanf("%d", &choice);

                    // Checking costs time
                    timeLeft--;
                    printf("Time Remaining: %d\n", timeLeft);

                    if (choice == 1) {
                        printf("You found a rope!\n");
                        printf("You use it to cross safely.\n");
                        currentRoom = SECRET_ROOM;

                    } else {
                        printf("You fall into the pit!\n");

                        // Player takes damage
                        changeHealth(&health, -1);

                        if (health <= 0) {
                            gameOver = 1;
                            break;
                        }
                    }
                    
                    break;
                }
                // ================= ROOM 3 - SECRET ROOM =================
                case SECRET_ROOM: {

                    int choice;
                    int leverCode[5] = {1, 1, 0, 1, 0};

                    printf("----------------------------------\n");
                    printf("A strange wall catches your eye.\n");

                    while (1) {
                        printf("Do you want to look around? 1 = yes 0 = continue\n");
                        scanf("%d", &choice);

                        if (choice == 1) {
                            timeLeft--;
                            printf("Time Remaining: %d\n", timeLeft);

                            printf("You found a hidden door to a secret room!\n");

                            while (1) {
                                printf("Open it? 1 = yes 0 = no\n");
                                scanf("%d", &choice);

                                if (choice == 1) {
                                    printf("You enter the secret room.\n");
                                    printf("You found a secret elixir!\n");

                                    // Player gained health
                                    changeHealth(&health, 2);

                                    printf("Carved into the wall is an ancient code:\n");
                                    printf("[%d, %d, %d, %d, %d]\n",
                                           leverCode[0], leverCode[1], leverCode[2],
                                           leverCode[3], leverCode[4]);

                                    currentRoom = EXIT_CHAMBER;
                                    break;
                                } else {
                                    printf("You hesitate at the doorway.\n");
                                    printf("A dart trap fires from the wall!\n");

                                    // Player takes damage
                                    changeHealth(&health, -1);

                                    if (health <= 0) {
                                        gameOver = 1;
                                        break;
                                    }
                                }
                            }

                            break;
                        } else {
                            printf("You try to move on too quickly.\n");
                            printf("A hidden trap activates!\n");

                            // Player takes damage
                            changeHealth(&health, -1);

                            if (health <= 0) {
                                gameOver = 1;
                                break;
                            }
                        }
                    }

                    if (!gameOver && currentRoom != EXIT_CHAMBER) {
                        currentRoom = EXIT_CHAMBER;
                    }

                    break;
                }

                // ================= ROOM 4 - EXIT CHAMBER =================
                case EXIT_CHAMBER: {

                    // Entering room costs time
                    timeLeft--;
                    printf("Time Remaining: %d\n", timeLeft);

                    int choice;

                    printf("----------------------------------\n");
                    printf("Exit Chamber:\n");

                    // If time runs out immediately
                    if (timeLeft <= 0) {
                        gameOver = 1;
                        break;
                    }

                    // Search for key
                    printf("Search for Ancient Key? 1 = yes 0 = no\n");
                    scanf("%d", &choice);

                    // Searching costs time
                    timeLeft--;
                    printf("Time Remaining: %d\n", timeLeft);

                    if (choice == 0 || timeLeft <= 0) {
                        printf("You are trapped in the tomb.\n");
                        gameOver = 1;
                        break;
                    }

                    printf("You found the Ancient Key!\n");
                    
                    int solved = 0;
                    int lever[5];
                    int correct[5] = {1, 1, 0, 1, 0};
                    int i;
                    int match;

                    printf("Five ancient levers stand before you.\n");
                    printf("Hint: The door opens with the number 26.\n");

// Player stays here until correct answer, death, or time runs out
                    while (!solved && timeLeft > 0 && health > 0) {

                    match = 1;

                    printf("Enter lever positions (1 or 0):\n");
                    for (i = 0; i < 5; i++) {
                    scanf("%d", &lever[i]);
                    }

    // Each attempt costs time
                    timeLeft--;
                    printf("Time Remaining: %d\n", timeLeft);

                    for (i = 0; i < 5; i++) {
                        if (lever[i] != correct[i]) {
                        match = 0;
                        break;
                        }
                    }

                    if (match == 1) {
                    solved = 1;
                    } else {
                        printf("Incorrect combination.\n");

        // Player takes damage
                    changeHealth(&health, -1);

                    if (health <= 0) {
                        gameOver = 1;
                        break;
                        }
                    }
                }

                    // Outcome logic
                    if (solved && timeLeft > 0 && health > 0) {

                        while (1) {
                            printf("A hidden door appears. Use key? 1 = yes 0 = no\n");
                            scanf("%d", &choice);

                            timeLeft--;
                            printf("Time Remaining: %d\n", timeLeft);

                            if (choice == 1 && timeLeft > 0) {
                                printf("You escape the pyramid!\n");
                                break;
                            } else if (choice == 0 && timeLeft > 0) {
                                printf("You hesitate, and the tomb punishes your doubt.\n");

                                // Player takes damage
                                changeHealth(&health, -1);

                                if (health <= 0) {
                                    gameOver = 1;
                                    break;
                                }
                            } else {
                                printf("You hesitate. Time runs out.\n");
                                gameOver = 1;
                                break;
                            }
                        }

                    } else {
                        printf("The Pharaoh awakens!\n");

                        if (timeLeft <= 0 && health > 0) {
                            printf("You ran out of time and couldn't use your remaining health.\n");
                        }

                        health = 0;
                    }

                    // End game after Exit Chamber
                    gameOver = 1;
                    break;
                }

            } // end switch

        } // end main game loop

        // If time ran out outside Exit Chamber
        if (timeLeft <= 0 && !gameOver) {
            printf("\nTime has run out.\n");
            printf("The Pharaoh awakens!\n");
        }

        printf("----------------------------------\n");
        printf("Play again? 1 = yes 0 = no\n");
        scanf("%d", &playAgain);

    } // end replay loop

    printf("Goodbye\n");
    return 0;
}
